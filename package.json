{
  "name": "gesp-classification-catalog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "GESP problem-type classification and knowledge alignment catalog.",
  "scripts": {
    "dev:api": "tsx watch apps/api/src/main.ts",
    "dev:web": "vite --config apps/web/vite.config.ts --host 0.0.0.0",
    "build:api": "tsc -p apps/api/tsconfig.json",
    "build:web": "tsc -p apps/web/tsconfig.json && vite build --config apps/web/vite.config.ts",
    "db:up": "docker compose up -d mysql",
    "db:seed": "node scripts/seed-mysql-catalog.mjs",
    "validate:db": "node scripts/validate-mysql-catalog.mjs",
    "ingest:official": "node scripts/ingest-official-sources.mjs",
    "ingest:oj": "node scripts/ingest-oj-mirrors.mjs",
    "align:canonical": "node scripts/align-canonical-problems.mjs",
    "classify:level-domain": "node scripts/classify-level-domains.mjs",
    "extract:problem-knowledge": "node scripts/extract-problem-types-knowledge.mjs",
    "model:conflict-confidence": "node scripts/build-conflict-confidence-model.mjs",
    "build:answer-guidance": "node scripts/build-answer-guidance.mjs",
    "build:problem-details": "node scripts/build-problem-details.mjs",
    "build:supplemental-cxx": "node scripts/build-supplemental-cxx-problems.mjs",
    "build:python-learning-paths": "node scripts/build-python-learning-paths.mjs",
    "export:audit": "node scripts/export-audit-dataset.mjs",
    "restore:audit": "node scripts/restore-audit-sources.mjs",
    "plan:next-public-oj": "node scripts/plan-next-public-oj-enrichment.mjs",
    "plan:review-workqueue": "node scripts/plan-review-workqueue.mjs",
    "enrich:public-oj": "node scripts/enrich-public-oj-details.mjs",
    "enrich:official-programming": "node scripts/enrich-official-programming-oj-details.mjs",
    "extract:official-pdf-assets": "PYTHONPATH=.python-deps python3 scripts/extract-official-pdf-visual-assets.py",
    "apply:public-oj-enrichment": "node scripts/apply-public-oj-enrichment.mjs",
    "apply:official-pdf-assets": "node scripts/apply-official-pdf-visual-assets.mjs",
    "apply:official-level5-statements": "node scripts/apply-official-level5-statement-enrichment.mjs",
    "apply:official-programming-enrichment": "node scripts/apply-official-programming-enrichment.mjs",
    "apply:ai-reference-solutions": "node scripts/apply-ai-reference-solutions.mjs",
    "apply:official-ai-reference-solutions": "node scripts/apply-official-ai-reference-solutions.mjs",
    "refine:official-programming-classification": "node scripts/refine-official-programming-classification.mjs",
    "refine:supplemental-classification": "node scripts/refine-supplemental-classification.mjs",
    "parse:official-pdfs": "node scripts/parse-official-pdfs.mjs",
    "parse:official-pdfs:python": "node scripts/parse-official-pdfs.mjs --all-sessions --language Python --output data/problem-ingestion/official-python-pdf-problems.json",
    "validate:canonical-alignment": "node scripts/validate-canonical-alignment.mjs",
    "validate:level-domain-classification": "node scripts/validate-level-domain-classification.mjs",
    "validate:problem-knowledge": "node scripts/validate-problem-knowledge.mjs",
    "validate:conflict-confidence": "node scripts/validate-conflict-confidence.mjs",
    "validate:answer-guidance": "node scripts/validate-answer-guidance.mjs",
    "validate:problem-details": "node scripts/validate-problem-details.mjs",
    "validate:supplemental-cxx": "node scripts/validate-supplemental-cxx-problems.mjs",
    "validate:public-oj-enrichment": "node scripts/validate-public-oj-enrichment.mjs",
    "validate:official-pdf-assets": "node scripts/validate-official-pdf-visual-assets.mjs",
    "validate:official-programming-enrichment": "node scripts/validate-official-programming-enrichment.mjs",
    "validate:ai-reference-solutions": "node scripts/validate-ai-reference-solutions.mjs",
    "validate:official-ai-reference-solutions": "node scripts/validate-official-ai-reference-solutions.mjs",
    "validate:official-programming-classification": "node scripts/validate-official-programming-classification-refinements.mjs",
    "validate:supplemental-classification": "node scripts/validate-supplemental-classification-refinements.mjs",
    "validate:catalog-api": "node scripts/validate-catalog-api.mjs",
    "validate:catalog-crud": "node scripts/validate-catalog-crud.mjs",
    "validate:audit-export": "node scripts/validate-audit-export.mjs",
    "validate:multi-level-expansion": "node scripts/validate-multi-level-expansion.mjs",
    "validate:python-learning-paths": "node scripts/validate-python-learning-paths.mjs",
    "validate:review-action-logic": "node scripts/validate-review-action-logic.mjs",
    "validate:review-workflow-api": "node scripts/validate-review-workflow-api.mjs",
    "validate:review-workqueue": "node scripts/validate-review-workqueue-plan.mjs",
    "validate:oj-ingestion": "node scripts/validate-oj-ingestion.mjs",
    "validate:pdf-parser": "node scripts/validate-pdf-parser.mjs",
    "validate:official-ingestion": "node scripts/validate-official-ingestion.mjs",
    "validate:sources": "node scripts/validate-source-registry.mjs"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-express": "^11.1.24",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "lucide-react": "^1.17.0",
    "mysql2": "^3.22.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}
